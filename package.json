{
  "name": "d3-capture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false --exclude '.next/**' --exclude 'node_modules/**' --exclude '*.db' server/index.ts",
    "dev:debug": "LOG_LEVEL=debug tsx watch --clear-screen=false --exclude '.next/**' --exclude 'node_modules/**' --exclude '*.db' server/index.ts | pino-pretty",
    "dev:debug:log": "LOG_LEVEL=debug tsx watch --clear-screen=false --exclude '.next/**' --exclude 'node_modules/**' --exclude '*.db' server/index.ts | tee -a _tmp/logs.txt | pino-pretty",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "NODE_ENV=production prisma migrate deploy && tsx server/index.ts",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@deepgram/sdk": "^4.11.3",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@tailwindcss/typography": "^0.5.19",
    "dotenv": "^17.3.1",
    "mermaid": "^11.12.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "openai": "^6.22.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
